# Copy this file to .env.local and fill in the values.
# In production, set these in the Vercel dashboard (Settings > Environment Variables).

# --- Admin authentication ---
# Password for the admin login (/admin/login).
ADMIN_PASSWORD=
# Secret used to sign admin session JWTs. REQUIRED — the admin login fails without it.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMIN_EMAIL=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- PayPal ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_ENVIRONMENT=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# --- ISR on-demand revalidation ---
REVALIDATION_SECRET=
